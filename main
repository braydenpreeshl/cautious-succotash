import React, { useEffect, useMemo, useRef, useState } from "react";

/**
 * PrepPal Desktop (Web) – Single‑file React App (MVP)
 * ---------------------------------------------------
 * "Runs in canvas" build: No server, no external APIs. Local-first with localStorage.
 * Implements:
 *  - Planner (courses, assignments, suggested study sessions, day/week views, reschedule)
 *  - Flashcards (decks, cards, SM-2 spaced repetition, swipe-like study)
 *  - Essay Coach (basic inline suggestions with Accept/Reject)
 *  - Gamification (streaks, badges), Premium gating, Profile/Settings
 *  - Mock auth (Google/Apple/email placeholders)
 *
 * Notes:
 *  - This is a compact MVP. It’s ready to extend with real auth, sync, ASR, and LMS import.
 *  - Styling uses a lightweight utility approach without external CSS frameworks to keep compatibility.
 */

/*********************************
 * Utilities & Local Persistence  *
 *********************************/
const LS_KEY = "preppal_state_v1";

function uid(prefix = "id") {
  return `${prefix}_${Math.random().toString(36).slice(2, 9)}_${Date.now().toString(36)}`;
}

function saveState(state) {
  localStorage.setItem(LS_KEY, JSON.stringify(state));
}

function loadState() {
  const raw = localStorage.getItem(LS_KEY);
  if (!raw) return null;
  try {
    return JSON.parse(raw);
  } catch {
    return null;
  }
}

function todayISO(d = new Date()) {
  const t = new Date(d);
  t.setHours(0, 0, 0, 0);
  return t.toISOString().slice(0, 10);
}

function addDays(date, days) {
  const d = new Date(date);
  d.setDate(d.getDate() + days);
  return d;
}

function clamp(n, min, max) { return Math.max(min, Math.min(max, n)); }

